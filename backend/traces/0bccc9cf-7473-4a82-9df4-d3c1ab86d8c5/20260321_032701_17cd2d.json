                  "name": "run_python",
                  "args": {
                    "code": "import altair as alt\nimport pandas as pd\n\ndf = _db.execute(\"SELECT quarter, fed_funds_rate FROM us_quarterly_macro_0047798b ORDER BY quarter\").df()\n\n# Histogram of fed funds rate distribution\nhist = alt.Chart(df).mark_bar(color='steelblue').encode(\n    x=alt.X('fed_funds_rate:Q', title='Fed Funds Rate (%)', bin=True),\n    y='count()',\n    tooltip=['fed_funds_rate', 'count()']\n).properties(\n    width=400,\n    height=300\n)\n\n# Add density curve\ndensity = alt.Chart(df).mark_area(opacity=0.3, color='darkorange').encode(\n    x='fed_funds_rate:Q',\n    y='density()',\n    tooltip=['fed_funds_rate', 'density()']\n).properties(\n    width=400,\n    height=300\n)\n\ncombined = hist + density\n\nhist = styled_chart(hist, \"Distribution of Fed Funds Rate (Histogram)\")\ndensity = styled_chart(density, \"Fed Funds Rate Density\")\nsave_chart_vegalite(combined, \"Fed Funds Rate Distribution\")\n\nprint_full(df)"
                  }
                }
              ]
            }
