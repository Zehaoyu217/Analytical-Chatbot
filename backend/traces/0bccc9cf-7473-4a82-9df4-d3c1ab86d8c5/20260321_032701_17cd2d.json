                    "sql": "SELECT \n  COUNT(*) as n,\n  MIN(fed_funds_rate) as min_rate,\n  MAX(fed_funds_rate) as max_rate,\n  AVG(fed_funds_rate) as mean_rate,\n  MEDIAN(fed_funds_rate) as median_rate,\n  STDDEV_SAMP(fed_funds_rate) as std_dev,\n  QUANTILE_CONT(fed_funds_rate, 0.25) as q1,\n  QUANTILE_CONT(fed_funds_rate, 0.75) as q3\nFROM us_quarterly_macro_0047798b"
