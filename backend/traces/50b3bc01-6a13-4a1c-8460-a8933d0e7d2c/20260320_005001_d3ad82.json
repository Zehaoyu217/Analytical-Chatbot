                  "name": "run_python",
                  "args": {
                    "code": "from statsmodels.tsa.stattools import adfuller\n\n# Query the real_gdp data from the table\ndf = _db.execute(\"\"\"\n    SELECT date, real_gdp \n    FROM us_macro_quarterly_fred_126b4cea \n    ORDER BY date\n\"\"\").df()\n\nprint(\"Data shape:\", df.shape)\nprint(\"Date range:\", df['date'].min(), \"to\", df['date'].max())\nprint(\"\\nFirst 10 rows:\")\nprint(df.head(10))\n\n# Run ADF test\nprint(\"\\n\" + \"=\"*50)\nprint(\"ADF Unit Root Test on real_gdp\")\nprint(\"=\"*50)\n\nresult = adfuller(df['real_gdp'], autolag='AIC')\n\n# Display results\nprint(f\"\\nADF Test Statistic: {result[0]:.4f}\")\nprint(f\"Critical Values:\")\nfor key, value in result[4].items():\n    print(f\"  {key}: {value:.4f}\")\nprint(f\"\\nTest Statistics:\")\nprint(f\"  1%: {result[1]:.4f}\")\nprint(f\"  2%: {result[2]:.4f}\")\nprint(f\"  5%: {result[3]:.4f}\")\nprint(f\"  10%: {result[4]:.4f}\")\nprint(f\"\\nTest Statistic: {result[0]:.4f}\")\nprint(f\"P-value: {result[1]:.4f}\")\nprint(f\"Number of Observations Used: {result[5]}\")\nprint(f\"Number of Terms Included in Automatic Lag Selection: {result[6]}\")\n\n# Interpretation\nprint(\"\\n\" + \"=\"*50)\nprint(\"Interpretation:\")\nprint(\"=\"*50)\nif result[0] < result[4]['1%']:\n    print(\"Result: Reject null hypothesis at 1% significance level\")\n    print(\"Conclusion: real_gdp is stationary at 1% level\")\nelif result[0] < result[4]['5%']:\n    print(\"Result: Reject null hypothesis at 5% significance level\")\n    print(\"Conclusion: real_gdp is stationary at 5% level\")\nelse:\n    print(\"Result: Fail to reject null hypothesis\")\n    print(\"Conclusion: real_gdp is NOT stationary (has a unit root)\")"
                  }
                }
