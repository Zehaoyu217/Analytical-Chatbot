                    "code": "import altair as alt\nimport pandas as pd\n\n# Query the fed funds rate data\ndf = _db.execute(\"\"\"\n    SELECT quarter, fed_funds_rate \n    FROM us_quarterly_macro_0047798b\n\"\"\").df()\n\n# Create histogram\nchart = alt.Chart(df).mark_bar(\n    cornerRadiusTopLeft=4, \n    cornerRadiusTopRight=4, \n    opacity=0.8, \n    color='#6366f1'\n).encode(\n    x=alt.X(\"fed_funds_rate:Q\", bin=alt.Bin(maxbins=35)),\n    y=\"count()\",\n    tooltip=[\"fed_funds_rate:Q\", \"count()\"]\n)\n\nchart = styled_chart(chart, \"Histogram of Fed Funds Rate\")\nsave_chart_vegalite(chart, \"Histogram of Fed Funds Rate\")"
